# Environment variables for Smart Home Backend
# Copy this to .env and fill in your values

# Application
SMARTHOME_ENVIRONMENT=development
SMARTHOME_SERVER_PORT=8080
SMARTHOME_LOG_LEVEL=info

# Database  
SMARTHOME_DATABASE_URL=postgres://user:password@localhost:5432/smarthome?sslmode=disable
SMARTHOME_REDIS_URL=redis://localhost:6379

# Security
SMARTHOME_JWT_SECRET=your-secret-key-here

# CORS Origins (comma-separated)
SMARTHOME_CORS_ORIGINS=http://localhost:3000,http://localhost:8080